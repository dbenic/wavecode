# WaveCode Environment Variables
# Copy this to .env and fill in your values.
# These are fallbacks — config.yaml takes priority.

# API keys for command chat, research, and prompt enhancement
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=

# Auth token (required if auth.method is 'token' in config.yaml)
# WAVECODE_AUTH_TOKEN=

# Override server port (default: 3777)
# WAVECODE_PORT=3777

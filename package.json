{
  "name": "wavecode",
  "version": "0.1.0",
  "description": "Autonomous multi-agent CLI orchestration platform",
  "type": "module",
  "main": "dist/server/index.js",
  "exports": "./dist/server/index.js",
  "bin": {
    "wavecode": "./dist/cli/index.js"
  },
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:ui": "npm --prefix src/ui run dev",
    "clean": "rm -rf dist src/ui/dist",
    "build": "npm run clean && npm run build:server && npm run build:ui",
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "npm --prefix src/ui run build",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p src/ui/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild:native": "npm rebuild better-sqlite3",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "Apache-2.0",
  "files": [
    "dist",
    "src/ui/dist",
    "scripts",
    "config.example.yaml",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@hono/node-server": "^1.19.12",
    "ansi-to-html": "^0.7.2",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "dompurify": "^3.3.3",
    "hono": "^4.12.9",
    "js-yaml": "^4.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.59.1",
    "simple-git": "^3.33.0",
    "ulid": "^3.0.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
